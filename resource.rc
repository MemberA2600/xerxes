#include "winparam.h"

///////////////////////////////////////////////////
//
// Parameter Definitions
//
#define IDM_MAIN        30001
#define ID_SCREENSIZE   40001
#define IDF_DEBUGTXT     1001
#define IDD_DEBUGMSG      102
#define ID_DEBUGOK       1002
#define ID_AUTO         40002
#define ID_320x240      40003
#define ID_640x480      40004
#define ID_800x600      40005
#define ID_1024x768     40006
#define ID_1152x864     40007
#define ID_1280x960     40008
#define ID_1400x1050    40009
#define ID_1600x1200    40010
#define ID_2048x1536    40011
#define ID_SPEED        40012
#define ID_SPEED1       40013
#define ID_SPEED2       40014
#define ID_SPEED3       40015
#define ID_SPEED4       40016
#define ID_SPEED5       40017
#define ID_DEV          40018
#define ID_TIA_Noiser   40019
#define IDD_GENBEEP       101
#define ID_GENBEEP_GEN   1003
#define ID_GENBEEP_SAVE  1004
#define ID_GENBEEP_PLAY  1005
#define ID_TIAINPUT      1006
#define IDD_TIA           104
#define ID_TIAName       1007
#define ID_TIAErase      1011
#define ID_TIASave       1012
#define ID_TIAPlay       1013
#define ID_TIALoad       1014
#define IDF_STRING4      1016

///////////////////////////////////////////////////
//
// Dialogs
//
IDD_DEBUGMSG DIALOG 0,0,273,57
STYLE WS_POPUP | WS_BORDER | WS_DLGFRAME | WS_SYSMENU | DS_3DLOOK | DS_MODALFRAME
FONT 8, "MS Shell Dlg"
CAPTION "Debug Info"
BEGIN
  CONTROL "",IDF_DEBUGTXT,"STATIC",WS_CHILD | WS_VISIBLE | WS_GROUP | SS_LEFT,12,8,248,20
  CONTROL "OK",ID_DEBUGOK,"BUTTON",WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP | BS_DEFPUSHBUTTON | BS_TEXT,112,36,40,14
END

IDD_GENBEEP DIALOG 0,0,173,92
STYLE WS_POPUP | WS_BORDER | WS_DLGFRAME | WS_SYSMENU | DS_3DLOOK | DS_MODALFRAME
FONT 8, "MS Shell Dlg"
CAPTION "Beep Generator"
BEGIN
  CONTROL "Generate Beep",ID_GENBEEP_GEN,"BUTTON",WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP | BS_PUSHBUTTON | BS_TEXT,32,10,110,20
  CONTROL "Save Beep",ID_GENBEEP_SAVE,"BUTTON",WS_CHILD | WS_VISIBLE | WS_DISABLED | WS_GROUP | WS_TABSTOP | BS_PUSHBUTTON | BS_TEXT,32,61,110,20
  CONTROL "Play Beep",ID_GENBEEP_PLAY,"BUTTON",WS_CHILD | WS_VISIBLE | WS_DISABLED | WS_GROUP | WS_TABSTOP | BS_PUSHBUTTON | BS_TEXT,32,35,110,20
END

IDD_TIA DIALOG 0,0,189,142
STYLE WS_POPUP | WS_BORDER | WS_DLGFRAME | WS_SYSMENU | DS_3DLOOK | DS_MODALFRAME
FONT 8, "MS Shell Dlg"
CAPTION "TIA Noise Maker"
BEGIN
  CONTROL "Erase",ID_TIAErase,"BUTTON",WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP | BS_DEFPUSHBUTTON | BS_TEXT,6,122,40,14
  CONTROL "Load",ID_TIALoad,"BUTTON",WS_CHILD | WS_VISIBLE | WS_TABSTOP | BS_PUSHBUTTON | BS_TEXT,50,122,40,14
  CONTROL "Save",ID_TIASave,"BUTTON",WS_CHILD | WS_VISIBLE | WS_TABSTOP | BS_PUSHBUTTON | BS_TEXT,94,122,40,14
  CONTROL "Play",ID_TIAPlay,"BUTTON",WS_CHILD | WS_VISIBLE | WS_TABSTOP | BS_PUSHBUTTON | BS_TEXT,138,121,40,14
  CONTROL "Puking Ears",ID_TIAName,"EDIT",WS_CHILD | WS_VISIBLE | WS_BORDER | WS_TABSTOP | ES_LEFT,7,101,169,14
  CONTROL "String",IDF_STRING4,"EDIT",WS_CHILD | WS_VISIBLE | WS_BORDER | WS_TABSTOP | ES_LEFT,266,172,40,14
  CONTROL "",ID_TIAINPUT,"EDIT",WS_CHILD | WS_VISIBLE | WS_BORDER | WS_VSCROLL | WS_GROUP | WS_TABSTOP | ES_LEFT | ES_MULTILINE | ES_WANTRETURN,9,7,168,90
END

IDD_TIA RCDATA
BEGIN
"[Lengths] \n"
"1007 25 \n"
,0
END

///////////////////////////////////////////////////
//
// Menus
//
IDM_MAIN MENU
BEGIN
  POPUP "Resolution"
  BEGIN
    MENUITEM "Auto",ID_AUTO
    MENUITEM "320x240",ID_320x240
    MENUITEM "640x480",ID_640x480
    MENUITEM "800x600",ID_800x600
    MENUITEM "1024x768",ID_1024x768
    MENUITEM "1152x864",ID_1152x864
    MENUITEM "1280x960",ID_1280x960
    MENUITEM "1400x1050",ID_1400x1050
    MENUITEM "1600x1200",ID_1600x1200
    MENUITEM "2048x1536",ID_2048x1536
  END
  POPUP "Screen Refresh"
  BEGIN
    MENUITEM "Lightning",ID_SPEED1
    MENUITEM "Rocket",ID_SPEED2
    MENUITEM "Cheetah",ID_SPEED3
    MENUITEM "Hare",ID_SPEED4
    MENUITEM "Snail",ID_SPEED5
  END
  POPUP "Development"
  BEGIN
    MENUITEM "TIA Noise Maker",ID_TIA_Noiser
  END
END

IDM_MAIN RCDATA
BEGIN
ID_SCREENSIZE,1,0,
ID_SPEED,2,0,
ID_DEV,3,0,
0
END

